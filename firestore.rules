rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kanimation641@gmail.com" && request.auth.token.email_verified == true);
    }

    match /announcements/global {
      allow read: if true; // Publicly readable so everyone sees announcements
      allow write: if isAdmin(); // Only admin can send announcements
    }
  }
}
