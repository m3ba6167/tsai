{
  "entities": {
    "Announcement": {
      "title": "Announcement",
      "description": "Global announcement message",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The announcement text"
        },
        "sender": {
          "type": "string",
          "description": "The nickname of the sender"
        },
        "timestamp": {
          "type": "number",
          "description": "Creation timestamp"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the announcement is currently active"
        }
      },
      "required": ["text", "sender", "timestamp", "active"]
    },
    "User": {
      "title": "User",
      "description": "User profile and game state",
      "type": "object",
      "properties": {
        "nickname": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "eggs": { "type": "number", "description": "Number of eggs owned" },
        "coins": { "type": "number", "description": "Number of coins owned" },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified" },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium access" },
        "isBanned": { "type": "boolean", "description": "Whether the user is banned" },
        "pets": { "type": "array", "items": { "type": "object" }, "description": "List of pets owned" },
        "profilePic": { "type": "string", "description": "URL to user's profile picture" },
        "lastUpdate": { "type": "number", "description": "Last sync timestamp" }
      },
      "required": ["nickname", "email", "eggs", "coins", "isVerified", "isPremium", "isBanned", "pets", "lastUpdate"]
    }
  },
  "firestore": {
    "/announcements/global": {
      "schema": "Announcement",
      "description": "The single global announcement document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    }
  }
}
