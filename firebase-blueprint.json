{
  "entities": {
    "Announcement": {
      "title": "Announcement",
      "description": "Global announcement message",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The announcement text"
        },
        "sender": {
          "type": "string",
          "description": "The nickname of the sender"
        },
        "timestamp": {
          "type": "number",
          "description": "Creation timestamp"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the announcement is currently active"
        }
      },
      "required": ["text", "sender", "timestamp", "active"]
    }
  },
  "firestore": {
    "/announcements/global": {
      "schema": "Announcement",
      "description": "The single global announcement document"
    }
  }
}
